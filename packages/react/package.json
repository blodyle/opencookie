{
  "name": "@opencookie/react",
  "version": "0.1.0-alpha.0",
  "description": "Tiny, frontend-only consent gating for React and Next.js apps.",
  "license": "MIT",
  "type": "module",
  "sideEffects": false,
  "homepage": "https://github.com/blodyle/opencookie#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/blodyle/opencookie.git",
    "directory": "packages/react"
  },
  "bugs": {
    "url": "https://github.com/blodyle/opencookie/issues"
  },
  "keywords": [
    "cookies",
    "consent",
    "cookie-consent",
    "privacy",
    "google-consent-mode",
    "react",
    "nextjs",
    "gdpr"
  ],
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./config": {
      "types": "./dist/config-entry.d.ts",
      "import": "./dist/config-entry.js",
      "require": "./dist/config-entry.cjs"
    }
  },
  "scripts": {
    "build": "tsup src/index.ts src/config-entry.ts --format esm,cjs --dts --external react --clean",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --project tsconfig.json"
  },
  "peerDependencies": {
    "react": ">=18.2.0"
  }
}
